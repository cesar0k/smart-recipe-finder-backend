# Secret key for signing JWT tokens.
SECRET_KEY=change_me_to_a_random_hex_string_at_least_32_chars

# Port on which the FastAPI application will listen for incoming requests.
APP_PORT=8001

# List of origins that should be allowed to make cross-origin requests.
# Example: BACKEND_CORS_ORIGINS='["http://localhost:3000", "http://localhost:5173"]'
BACKEND_CORS_ORIGINS='["http://localhost:3000", "http://localhost:5173"]'

# Hostname of the database service. When using Docker Compose, this should be the service name (e.g., postgres).
DB_HOST=postgres
# Root password for the database server, used during initial setup (e.g., by Docker Compose).
DB_ROOT_PASSWORD=root_password
# Name of the database to connect to.
DB_NAME=recipes_db
# Username for the application to connect to the database.
DB_USER=user
# Password for the application's database user.
DB_PASSWORD=password
# Internal port of the PostgreSQL database container.
DB_INTERNAL_PORT=5432
# External port mapped to the PostgreSQL database container (for host access).
DB_EXTERNAL_PORT=5433

# Hostname for the ChromaDB vector store service.
CHROMA_HOST=chroma
# Port for the ChromaDB vector store service.
CHROMA_PORT=8000
# Name of the collection within ChromaDB to store recipe embeddings.
CHROMA_COLLECTION_NAME=recipes

# Hugging Face API token for accessing models (e.g., for embeddings). Obtainable from hf.co/settings/tokens
HF_TOKEN=YOUR_HUGGING_FACE_TOKEN
# The name of the embedding model to use for generating vector embeddings from recipe text.
# This model is used by the VectorStore to create embeddings for semantic search.
EMBEDDING_MODEL=intfloat/multilingual-e5-large-instruct

# Root username for MinIO object storage service.
MINIO_ROOT_USER=admin
# Root password for MinIO object storage service.
MINIO_ROOT_PASSWORD=minio_root_password

# Internal endpoint URL for S3 storage (used by the application to communicate with MinIO within the Docker network).
S3_ENDPOINT=http://minio:9000
# Public endpoint URL for S3 storage (used by the browser or external clients to access files directly).
S3_PUBLIC_ENDPOINT=http://localhost:9000

# Google OAuth2 (optional — leave empty to disable Google login).
# Obtain from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
